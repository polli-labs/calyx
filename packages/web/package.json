{
  "name": "@polli-labs/calyx-web",
  "version": "0.1.0",
  "description": "Web companion surface for Calyx.",
  "repository": {
    "type": "git",
    "url": "https://github.com/polli-labs/calyx",
    "directory": "packages/web"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --target node22 --tsconfig tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
