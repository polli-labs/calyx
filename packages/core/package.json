{
  "name": "@polli-labs/calyx-core",
  "version": "0.1.1-trusted.0",
  "description": "Core contracts and config compiler for Calyx.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --target node22 --tsconfig tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  }
}
