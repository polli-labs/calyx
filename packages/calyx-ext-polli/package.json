{
  "name": "calyx-ext-polli",
  "version": "0.1.0",
  "description": "First-party Polli extension for Calyx — registry pre-flight checks and fleet diagnostics.",
  "repository": {
    "type": "git",
    "url": "https://github.com/polli-labs/calyx",
    "directory": "packages/calyx-ext-polli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "calyx": {
    "apiVersion": "1",
    "domains": ["skills", "tools", "agents"]
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --target node22 --tsconfig tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@polli-labs/calyx-sdk": ">=0.1.0"
  },
  "devDependencies": {
    "@polli-labs/calyx-sdk": "workspace:*"
  }
}
